    "import java.util.*;",
    "import java.lang.*;",
    "",
    "class Solution {",
    "    private boolean isPrime(int n) {",
    "        if (n < 2) return false;",
    "        if (n == 2) return true;",
    "        if (n % 2 == 0) return false;",
    "        for (int i = 3; i <= Math.sqrt(n); i += 2) {",
    "            if (n % i == 0) return false;",
    "        }",
    "        return true;",
    "    }",
    "",
    "    public int primeFib(int n) {",
    "        int count = 0;",
    "        int a = 0, b = 1;",
    "",
    "        while (true) {",
    "            int fib = a + b;",
    "            a = b;",
    "            b = fib;",
    "",
    "            if (isPrime(fib)) {",
    "                count++;",
    "                if (count == n) return fib;",
    "            }",
    "        }",
    "    }",
    "}",
